{
  "name": "mdh-3d-store",
  "version": "2.0.0",
  "private": true,
  "description": "MDH 3D Store - Impressão 3D Profissional no Rio de Janeiro",
  "author": "MDH 3D",
  "license": "MIT",
  "keywords": [
    "3d-printing",
    "ecommerce",
    "nextjs",
    "react",
    "supabase"
  ],
  "engines": {
    "node": "24.x",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "start:3011": "next start --port 3011",
    "lint": "next lint --fix",
    "lint:check": "next lint",
    "typecheck": "tsc --noEmit",
    "typecheck:watch": "tsc --noEmit --watch",
    "test": "echo 'Tests temporarily disabled for deployment'",
    "test:watch": "echo 'Tests temporarily disabled for deployment'",
    "test:coverage": "echo 'Tests temporarily disabled for deployment'",
    "doctor": "node scripts/doctor.mjs",
    "admin:hash": "node scripts/admin-hash.mjs",
    "db:generate": "node scripts/db-generate.mjs",
    "db:migrate": "node scripts/db-migrate.mjs",
    "db:seed": "node scripts/db-seed.mjs",
    "catalog:images": "node scripts/catalog-images.mjs",
    "analyze": "ANALYZE=true npm run build",
    "preview": "npm run build && npm run start",
    "health": "powershell -Command \"Invoke-WebRequest http://127.0.0.1:3011/api/health -UseBasicParsing | Select-Object -ExpandProperty Content\"",
    "clean": "rm -rf .next out node_modules/.cache"
  },
  "dependencies": {
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.99.2",
    "@tailwindcss/aspect-ratio": "^0.4.2",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/typography": "^0.5.19",
    "@vercel/analytics": "^1.4.1",
    "@vercel/speed-insights": "^1.1.0",
    "clsx": "^2.1.1",
    "framer-motion": "^11.15.0",
    "lucide-react": "^0.468.0",
    "mercadopago": "^2.6.0",
    "next": "^15.0.0",
    "next-themes": "^0.4.4",
    "qrcode": "^1.5.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-intersection-observer": "^9.14.0",
    "sharp": "^0.33.5",
    "tailwind-merge": "^2.5.5",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@next/bundle-analyzer": "^15.0.0",
    "@prisma/client": "^7.5.0",
    "@snaplet/copycat": "^6.0.0",
    "@snaplet/seed": "^0.98.0",
    "@types/node": "^22.10.2",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "eslint-config-next": "^15.0.0",
    "postcss": "^8.4.49",
    "supabase": "^2.79.0",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2"
  }
}
