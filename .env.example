# ======================================
# CONFIGURAÇÃO SITE (Obrigatório)
# ======================================
# URL do site em produção
NEXT_PUBLIC_SITE_URL=https://mdh-3d-store.vercel.app

# Contatos WhatsApp (Obrigatório)
# Número principal em formato +55XX9XXXXXXXXX
NEXT_PUBLIC_WHATSAPP_NUMBER=5521920137249
# Números adicionais separados por vírgula (opcional)
NEXT_PUBLIC_EXTRA_WHATSAPP_NUMBERS=

# Mensagem padrão WhatsApp
NEXT_PUBLIC_WHATSAPP_MESSAGE=Oi! Vim pelo site da MDH 3D e quero um orçamento.

# Pix Provider (padrão: PicPay)
NEXT_PUBLIC_PIX_PROVIDER=PicPay
# Sufixo CPF para Pix
NEXT_PUBLIC_CPF_SUFFIX=85

# Redes Sociais (Obrigatório)
NEXT_PUBLIC_INSTAGRAM_URL=https://www.instagram.com/mdh_impressao3d/
NEXT_PUBLIC_INSTAGRAM_HANDLE=mdh_impressao3d
NEXT_PUBLIC_FACEBOOK_URL=
NEXT_PUBLIC_TIKTOK_URL=

# Email de notificações (Obrigatório)
STAFF_NOTIFY_EMAIL=mdhatendimento@gmail.com

# Admin (Segurança)
# Email do administrador (usar para login)
ADMIN_EMAIL=markmathias01@gmail.com

# Senha em texto puro apenas para bootstrap inicial do cofre local (opcional)
ADMIN_PASSWORD=

# Hash bcrypt da senha do admin (gerar com: npm run admin:hash)
# Obrigatório para autenticação segura
ADMIN_PASSWORD_HASH=

# Token de sessão (gerar com: openssl rand -hex 32)
# Usado para autenticação de cookies
ADMIN_SESSION_SECRET=seu_token_aleatorio_aqui_32chars

# Caminho do painel (padrão /admin)
ADMIN_HIDDEN_PATH=/admin

# Auth local do site
AUTH_CUSTOMER_SESSION_SECRET=troque-por-um-segredo-grande-e-aleatorio
AUTH_MAX_CUSTOMERS=100
AUTH_MAX_ADMINS=5

# ======================================
# SUPABASE - DATABASE & AUTH (Opcional)
# ======================================
# Em produção, alinhe URL pública, chave anon e chave de serviço no mesmo projeto Supabase
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_SECRET_KEY=

# Variáveis públicas para cliente/browser
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# Nomes das tabelas
SUPABASE_ORDERS_TABLE=orders
SUPABASE_QUOTES_TABLE=quotes
DATABASE_URL=

# ======================================
# ENTREGA - Cálculo de Frete
# ======================================
# Origem do envio (para cálculo de rota)
DELIVERY_ORIGIN_LABEL=Condominio Meu Lar 2

# Custos do transporte
GAS_PRICE_BRL=6
BIKE_KM_PER_LITER=35

# Taxa base de frete
DELIVERY_BASE_FEE=8
DELIVERY_FEE_PER_KM=0.6
DELIVERY_FEE_CAP=35

# Multiplicador para entrega express (2x = dobro do valor)
DELIVERY_EXPRESS_MULTIPLIER=2

# ======================================
# INTEGRAÇÕES DE PAGAMENTO (Opcional)
# ======================================

# Mercado Pago (para checkout web)
# Obter em: https://www.mercadopago.com.br/developers
MERCADOPAGO_ACCESS_TOKEN=
MERCADOPAGO_WEBHOOK_SECRET=

# WhatsApp Cloud API (para chatbot + notificações)
# Obter em: https://developers.facebook.com/docs/whatsapp/cloud-api
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_TEMPLATE_NAME=mdh_order_update

# Pix (backend - gerador de chave privada)
# Chave PIX do CPF ou CNPJ
PIX_KEY=
PIX_RECEIVER_NAME=
PIX_RECEIVER_CITY=RIO DE JANEIRO
